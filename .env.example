# Environment Configuration Template
# Copy file ini ke .env.local dan sesuaikan dengan environment Anda
# JANGAN push .env.local ke Git!

# Database Configuration
DB_HOST=localhost
DB_USER=perpus_user
DB_PASS=your_secure_password_here
DB_NAME=perpus_30

# Application Settings
APP_NAME=Aetheria Library
APP_ENV=production
APP_DEBUG=false

# Server Settings
SERVER_NAME=yourdomain.com
SERVER_PORT=80

# Email Configuration (optional)
MAIL_DRIVER=smtp
MAIL_HOST=smtp.mailtrap.io
MAIL_PORT=465
MAIL_USER=your_email@example.com
MAIL_PASS=your_email_password
MAIL_FROM_ADDRESS=noreply@aetheria.local
MAIL_FROM_NAME="Aetheria Library"

# File Upload Settings
MAX_UPLOAD_SIZE=5242880
UPLOAD_PATH=uploads/

# Session Settings
SESSION_LIFETIME=1800
SESSION_PATH=/tmp

# Security Settings
DENDA_PER_HARI=1000
PASSWORD_MIN_LENGTH=6
